# MoG configuration (loaded from this file if present).
# Environment variables set in the shell/container take precedence over this file.

# --- Mongo Wire Listener ---
# The port where MoG will listen for incoming MongoDB client connections.
MOG_MONGO_PORT=27017

# The username and password MoG will accept for SCRAM-SHA-256 authentication.
MOG_MONGO_USER=user
MOG_MONGO_PASSWORD=password

# --- MonkDB Backend (Postgres Wire) ---
# Connection details for your MonkDB (or Postgres-compatible) backend.
MOG_DB_HOST=127.0.0.1
MOG_DB_PORT=5432
MOG_DB_USER=monkdb
MOG_DB_PASSWORD=monkdb
MOG_DB_NAME=monkdb

# --- Observability ---
# Logging level: debug, info, warn, error.
MOG_LOG_LEVEL=info

# Slow-operation thresholds (milliseconds). Leave empty to keep defaults (100/50/150).
MOG_SLOW_QUERY_THRESHOLD_MS=
MOG_SLOW_SCAN_THRESHOLD_MS=
MOG_SLOW_ADAPTER_THRESHOLD_MS=

# Optional: Path to a file for structured logging.
# LOG_FILE=mog.log

# Port for the Prometheus metrics exporter (/metrics).
MOG_METRICS_PORT=8080

# --- Storage & Behavior ---
# If 1, MoG mirrors the full BSON document into a `data OBJECT(DYNAMIC)` column in MonkDB.
# If 0, only relational columns are stored (better for performance and storage).
MOG_STORE_RAW_MONGO_JSON=1

# If 1, ensures `_id` is always returned first and fields are sorted (adds overhead).
MOG_STABLE_FIELD_ORDER=0

# If 1, enables info-level logging for all insert/update/delete operations.
MOG_INFO_LOG_WRITES=0

# Change the default similarity used when MoG creates `FLOAT_VECTOR` columns.
# Accepted values:
#   euclidean (or `l2`), cosine (or `cosine_similarity`/`cosine-similarity`),
#   dot_product (or `dotproduct`/`dot-product`), maximum_inner_product (or `max_inner_product`/`mips`).
# Leave empty to let MonkDB use its own default (currently euclidean).
MOG_FLOAT_VECTOR_SIMILARITY=euclidean

# --- BLOB storage (MonkDB BLOB tables + /_blobs HTTP endpoints) ---
# Enable by setting a non-empty BLOB table name. Example:
#   CREATE BLOB TABLE media CLUSTERED INTO 3 SHARDS;
# MOG_BLOB_TABLE=media
MOG_BLOB_TABLE=media

# MonkDB HTTP base used for PUT/GET/DELETE to `/_blobs/<table>/<sha1>`.
# If MoG runs in Docker (macOS) and MonkDB runs on the host, use:
#   http://host.docker.internal:6000
MOG_BLOB_HTTP_BASE=http://localhost:6000

# Shard count used for best-effort BLOB table creation.
MOG_BLOB_SHARDS=3

# Only offload binary payloads >= this many bytes (default in code: 256).
MOG_BLOB_MIN_BYTES=256

# Optional: create/update a relational metadata table for audit/listing.
# MOG_BLOB_METADATA=1
# MOG_BLOB_METADATA_TABLE=doc.blob_metadata

# Optional: return Mongo-style inline Binary to clients by dereferencing stored __mog_blob__ pointers
# on reads (MoG will GET from MonkDB /_blobs). Off by default to avoid large payloads.
MOG_BLOB_INLINE_READS=0
MOG_BLOB_INLINE_MAX_BYTES=1048576
MOG_BLOB_INLINE_STRICT=0
